# ─────────────────────────────────────────
#  GymTracker — Environment Variables
# ─────────────────────────────────────────
#  Copy this file to .env and fill in values
#  cp .env.example .env

# MongoDB connection string
# Local:   mongodb://localhost:27017/gymtracker
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/gymtracker
MONGODB_URI=mongodb://localhost:27017/gymtracker

# Server port (default 5000)
PORT=5000

# JWT secret — change this to any long random string
JWT_SECRET=change_this_to_a_long_random_secret_string

# Client URL for CORS (default is Vite dev server)
CLIENT_URL=http://localhost:5173

# Node environment
NODE_ENV=development
